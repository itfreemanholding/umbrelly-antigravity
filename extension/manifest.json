{
    "manifest_version": 3,
    "name": "RevOps GigRadar Scanner",
    "version": "1.0",
    "description": "Mark and extract Upwork/GigRadar job posts for the RevOps platform.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "*://*.gigradar.io/*",
        "*://*.upwork.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://*.gigradar.io/*",
                "*://*.upwork.com/*"
            ],
            "js": [
                "content.js"
            ]
        },
        {
            "matches": [
                "http://localhost:5174/*"
            ],
            "js": [
                "app-sync.js"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    }
}